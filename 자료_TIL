export default function ServerFn(port) {
  // 1. ws 모듈 취득 
  const wsModule = require("ws"); 

  // 2. WebSocket 서버 Instance 생성
  const wss = new wsModule.Server({
    // server: HTTPServer 입력
    port: port
  }); 

  console.log("WebSocket Initialized", port);
  
  // 3. connection(to 클라이언트) event 처리
  wss.on("connection", (ws, request) => {

    // 1) 클라이언트로부터 메시지 수신 시 이벤트 처리
    ws.on("message", (message) => {
      console.log("received: %s", message);
      ws.send("Good, Nice to meet you, Iam server"); // 이 줄만 추가!
    });
  });
  
  // 4. 연결 종료 이벤트 처리
  wss.on("close", (error) => {
    console.log("webserver close", error);
  });
  
  // 5. 에러 처리
  wss.on("error", (error) => {
    console.log(error);
  });
}
```

