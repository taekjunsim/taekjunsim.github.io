const addTime = (e:React.MouseEvent<HTMLElement>) => {
  const { value } = (e.target as HTMLInputElement);
  const addTime = Number(value.slice(0, 2));

  if(value.includes('s')) {
    setSecond(sec.current += addTime); // 리렌더링
  } else if(value.includes('m')) {
    setMinute(min.current += addTime); // 리렌더링
  }
}

const startTimer = useCallback(() => {
  console.log('startTimer');
  restTime.current = sec.current + min.current*60;

  const tiktok = setInterval(() => {
    restTime.current += -1

    if(!min.current && !sec.current) {
      return (clearInterval(tiktok), setTimeout(() => alert('timeover'), 1));
    } else {
      return (
        (!!min.current && !sec.current)
          ? (setMinute(min.current - 1), sec.current = 59, setSecond(sec.current)) // 리렌더링
          : setSecond(sec.current += -1) // 리렌더링
      )
    };

  }, 1000)
}, []);
```

