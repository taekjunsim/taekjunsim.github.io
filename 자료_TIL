import React, {useRef} from "react";
import "./App.css";

function Client() {
  // 1. 웹소켓 클라이언트 객체 생성
  let ws = new WebSocket("ws://localhost:1234/ws");

  // 2. 웹소켓 이벤트 처리
  // 2-1) 연결 이벤트 처리
  ws.onopen = () => {
    console.log("connected!!");
  };

  let count = useRef(1);

  const sendMessage = () => {
    // 2-2) 서버에 메세지 보내기
    if(ws.readyState === ws.OPEN){
      ws.send(`증가하는 숫자를 보냅니다 => ${count.current}`); 
      count.current++;
    } else { 
      alert("연결된 웹소켓 서버가 없습니다."); 
    }      

    // 2-3) 서버에서 메세지 수신 시 이벤트 처리
    ws.onmessage = (evt) => {
      console.log(evt.data);
    };
  };

  // 2-4) 연결 종료 이벤트 처리
  const disconnect = () => {
    if(ws.readyState === ws.OPEN) {
      ws.close(); 
      console.log('disconnected');
    } else { 
      alert("연결된 웹소켓 서버가 없습니다."); 
    }
  }

  // 2-5) 에러 처리
  ws.onerror = (error) => {
    console.log(error);
  }

// 연결을 종료하는 method(close)는 존재하지만 재연결하는 method는 없는 듯하다.
// 재연결을 하려면 state를 이용해야 하나?

  return (
    <div className="App">
      <header className="App-header">
        {/* <button onClick={connect}>연결 하기</button> */}
        <button onClick={sendMessage}>메세지 보내기</button>
        <button onClick={disconnect}>연결 끊기</button>
      </header>
    </div>
  );
  
}

export default Client;
```

