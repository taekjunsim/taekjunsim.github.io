{
	let Rectangle = class {
		constructor(width, length) {
			this.length = length;
			this.width = width;
		}
	}

	class Cube extends Rectangle {
		constructor(width, length, height) {
			super(width, length);

			this.height = height;
		}

		calculateArea() {
			return this.width * this.length * this.height;
		}
	} 

